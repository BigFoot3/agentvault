# AgentVault — variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env dans Git

# ----------------------------------------------------------------
# Clé privée du wallet agent (Base Sepolia pour les tests)
# Générer avec : python -c "from web3 import Web3; w = Web3(); print(w.eth.account.create().key.hex())"
# ----------------------------------------------------------------
AGENT_PRIVATE_KEY=0x_VOTRE_CLE_PRIVEE_ICI

# ----------------------------------------------------------------
# Webhook Discord pour les alertes
# Créer dans : Paramètres du salon → Intégrations → Webhooks
# ----------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANNEL_ID/TOKEN

# ----------------------------------------------------------------
# Réseau blockchain
# "base-sepolia" pour les tests (gratuit), "base" pour la prod
# ----------------------------------------------------------------
CHAIN=base-sepolia

# ----------------------------------------------------------------
# RPC endpoint (optionnel — les défauts publics suffisent pour le MVP)
# Base Sepolia public  : https://sepolia.base.org
# Base mainnet public  : https://mainnet.base.org
# ----------------------------------------------------------------
# RPC_URL=https://sepolia.base.org

# ----------------------------------------------------------------
# Répertoire de stockage des états JSON (défaut : ./data)
# ----------------------------------------------------------------
# AGENTVAULT_DATA_DIR=./data
